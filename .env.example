# ===========================================
# AGS ELETRÔNICA - Environment Configuration
# ===========================================
# Copy this file to .env and adjust the values

# Node Environment
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=ags_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ags_eletronica
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3001
DATABASE_URL=postgresql://ags_user:CHANGE_ME@localhost:5432/ags_eletronica?schema=public

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3001/api

# Nginx
NGINX_PORT=80

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
